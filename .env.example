# Global
NODE_ENV=development

# React frontend
VITE_API_BASE_URL=http://localhost:4000

# Node API gateway
API_PORT=4000
PYTHON_SERVICE_URL=http://localhost:8001
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_RATE_LIMIT_PER_MINUTE=240

# Python Data Service
RANKRADAR_ENV=development
RANKRADAR_DB_PATH=./data/rankradar.sqlite3
DATADIVE_PROVIDER=mock
DATADIVE_API_KEY=
DATADIVE_API_BASE_URL=
DATADIVE_ORG_ID=
DATADIVE_SYNC_INTERVAL_MINUTES=60
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app-name>
MONGODB_DB=rankradar-os

# Optional configurable DataDive endpoint paths.
# Use these when your DataDive account/API documentation provides exact routes.
DATADIVE_ENDPOINT_BRANDS=/brands
DATADIVE_ENDPOINT_MARKETPLACES=/marketplaces
DATADIVE_ENDPOINT_PRODUCTS=/rank-radar/products
DATADIVE_ENDPOINT_PRODUCT_RANKS=/rank-radar/products/{product_id}
DATADIVE_ENDPOINT_VARIATION_RANKS=/rank-radar/products/{product_id}/keywords/{keyword_id}/variations

# Optional storage/notifications
DATABASE_URL=postgresql://rankradar:rankradar@localhost:5432/rankradar
REDIS_URL=redis://localhost:6379/0
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SLACK_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
